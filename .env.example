# Serverless Framework auth and AWS target account
SERVERLESS_ACCESS_KEY=replace_with_your_serverless_access_key
AWS_ACCOUNT_ID=123456789012
AWS_REGION=ap-southeast-2
SERVERLESS_ORG=quagntam

# AWS credentials for CLI/serverless deploy (do not commit real values)
AWS_ACCESS_KEY_ID=replace_with_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_secret_access_key
# AWS_SESSION_TOKEN=replace_with_session_token_if_needed

# App runtime config
APP_ENV=production
APP_CORS_ALLOW_ORIGINS=https://your-frontend.example.com,http://localhost:3000
ROOT_PATH=/dev
APP_API_KEY=replace_with_api_key

APP_OPTIMIZER_POPULATION_SIZE=200
APP_OPTIMIZER_GENERATIONS=500
APP_PARETO_OPTIONS_LIMIT=6
APP_RANDOMIZATION_STRENGTH=0.08
APP_RANDOM_SEED=42
