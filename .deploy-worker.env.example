# Example deploy environment file for deploy-worker.sh
# Copy this file to .deploy-worker.env and fill in real values.
AWS_ACCOUNT_ID=123456789012
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
SUBNET_IDS=subnet-aaaaaaa,subnet-bbbbbbb,subnet-ccccccc
QUEUE_ARN=arn:aws:sqs:ap-southeast-2:123456789012:your-queue-name
TABLE_NAME=your-table-name
BUCKET_NAME=your-bucket-name
AWS_REGION=ap-southeast-2
ECR_REPOSITORY=oade-nsga2-sls-worker
STACK_NAME=oade-nsga2-sls-worker-fargate
TEMPLATE_FILE=deploy/ecs-fargate/worker-fargate-stack.yaml
CPU=2048
MEMORY=4096
ASSIGN_PUBLIC_IP=DISABLED
